# Server
MCP_HOST=0.0.0.0
MCP_PORT=8020

# PostgreSQL
POSTGRES_HOST=scout-postgres
POSTGRES_PORT=5432
POSTGRES_DB=scout_db
POSTGRES_USER=scout_user
POSTGRES_PASSWORD=

# ChromaDB
CHROMA_MODE=server
CHROMA_HOST=scout-chroma
CHROMA_PORT=8000
CHROMA_PATH=./data/chroma_db

# Embeddings
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# LLM
LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=   # SC-036: LLM calls moved to agent side (Claude Code subscription)
#                      # Scout = deterministic tool: fetch + chunk + embed + search
#                      # Uncomment only for local dev/testing with scout_brief()
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Collector
PLAYWRIGHT_ENABLED=true

# Reranker
RERANKER_ENABLED=true   # false — отключить CrossEncoder для быстрых тестов

# Redis Streams (streaming pipeline)
REDIS_URL=redis://scout-redis:6379/0
REDIS_STREAMING=false

# Research defaults
DEFAULT_DEPTH=normal
DEFAULT_CACHE_TTL_HOURS=24
MIN_SIMILARITY=0.60
